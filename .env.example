# .env.example
# Copiar a .env.local — NUNCA commitear .env.local

# URL base del servidor Traccar demo
NEXT_PUBLIC_TRACCAR_BASE=https://demo4.traccar.org

# Activar datos mock cuando la API no responde (true/false)
NEXT_PUBLIC_USE_MOCK=false

# URL del sitio — Netlify la setea automáticamente en producción
# En local: dejar vacío o http://localhost:8888 (con netlify dev)
URL=
